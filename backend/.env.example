# ── Server ───────────────────────────────────────────────────────────────
PORT=3000

# ── MongoDB ──────────────────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string.
# From: Atlas → Database → Connect → Drivers → Copy connection string.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/yes_native?retryWrites=true&w=majority

# ── Firebase Admin SDK ───────────────────────────────────────────────────
# Generate a private key in Firebase Console:
#   Project Settings → Service Accounts → Firebase Admin SDK → Generate new private key.
# Save the downloaded JSON file as `firebase-service-account.json` in the `config/` folder.
# Then set the path below:
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# ── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# For local Flutter web dev:
#   http://localhost:5000,http://localhost:5001
# For production, add your deployed app URLs.
CORS_ORIGINS=http://localhost:5000,http://localhost:5001,http://localhost:3000
