# ── Server ───────────────────────────────────────────────────────────────
PORT=3000

# ── MongoDB ──────────────────────────────────────────────────────────────
# Replace with your MongoDB Atlas connection string.
MONGODB_URI=mongodb://localhost:27017/yes_native

# ── Firebase Admin SDK ───────────────────────────────────────────────────
# Path to the Firebase service account JSON file.
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# ── CORS ─────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5000,http://localhost:5001,http://localhost:3000
